<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sistem Dokumentasi G-Drive</title>
  
  <!-- Tailwind CSS untuk Styling -->
  <script src="https://cdn.tailwindcss.com"></script>
  
  <!-- Import Map untuk memuat React dan Library -->
  <script type="importmap">
    {
      "imports": {
        "react": "https://esm.sh/react@18.2.0",
        "react-dom/client": "https://esm.sh/react-dom@18.2.0/client",
        "lucide-react": "https://esm.sh/lucide-react@0.292.0"
      }
    }
  </script>
  
  <!-- Babel -->
  <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
</head>
<body class="bg-slate-100">
  <div id="root"></div>

  <script type="text/babel" data-type="module">
    import React, { useState, useEffect, useRef } from 'react';
    import { createRoot } from 'react-dom/client';
    import { 
      FolderOpen, UploadCloud, Activity, CheckCircle, Clock, 
      FileText, ExternalLink, Trash2, HardDrive, Search, AlertCircle,
      Lock, User, LogOut, Users, UserPlus, Shield, Eye, EyeOff, Edit2, Save, X
    } from 'lucide-react';

    // =========================================================================
    // WAJIB: Masukkan URL Aplikasi Web (GAS) yang Anda salin dari Google Apps Script
    // =========================================================================
    const GAS_WEB_APP_URL = "https://script.google.com/macros/s/AKfycbzw3M_iibRuWfrvttDsna_HykEQ80xvbxmwv-talHOUrhqZry4aJUNumT2Wr-xZtE-f/exec";
    const LOGO_URL = "https://iili.io/BPHry3x.png";

    const FilePreview = ({ file }) => {
      const [error, setError] = useState(false);
      const isImage = /\.(jpe?g|png|gif|webp)$/i.test(file.newName);

      if (isImage && !error) {
        return (
          <img 
            src={`https://drive.google.com/thumbnail?id=${file.id}&sz=w120-h120`} 
            alt={file.newName} 
            className="w-11 h-11 object-cover rounded mr-3 flex-shrink-0 border border-slate-200 bg-slate-50"
            onError={() => setError(true)}
          />
        );
      }
      return (
        <div className="bg-blue-50 p-2.5 rounded mr-3 flex-shrink-0">
          <FileText className="text-blue-600" size={22}/>
        </div>
      );
    };

    function App() {
      // Auth State
      const [currentUser, setCurrentUser] = useState(null); // null = belum login
      const [loginUsername, setLoginUsername] = useState('');
      const [loginPassword, setLoginPassword] = useState('');
      const [showPassword, setShowPassword] = useState(false);
      const [isLoggingIn, setIsLoggingIn] = useState(false);
      const [authError, setAuthError] = useState('');

      // Main State
      const [activeTab, setActiveTab] = useState('upload');
      const [activities, setActivities] = useState([]);
      const [filesMetadata, setFilesMetadata] = useState([]);
      const [isLoadingData, setIsLoadingData] = useState(false);
      const [logoFailed, setLogoFailed] = useState(false);
      
      // Upload State
      const [activityTitle, setActivityTitle] = useState('');
      const [activityDate, setActivityDate] = useState('');
      const [selectedFiles, setSelectedFiles] = useState([]);
      const [uploadQueue, setUploadQueue] = useState([]);
      const [isUploading, setIsUploading] = useState(false);
      const fileInputRef = useRef(null);
      const [searchQuery, setSearchQuery] = useState('');

      // Admin State
      const [usersList, setUsersList] = useState([]);
      const [newUsername, setNewUsername] = useState('');
      const [newPassword, setNewPassword] = useState('');
      const [newRole, setNewRole] = useState('gtk');
      const [isManagingUser, setIsManagingUser] = useState(false);
      const [editingUser, setEditingUser] = useState(null);
      const [editPasswordValue, setEditPasswordValue] = useState('');

      // Cek sesi login yang tersimpan (opsional)
      useEffect(() => {
        const savedUser = localStorage.getItem('smp_darul_madinah_user');
        if (savedUser) {
          setCurrentUser(JSON.parse(savedUser));
        }
      }, []);

      // --- AUTHENTICATION HANDLERS ---
      const handleLogin = async (e) => {
        e.preventDefault();
        setAuthError('');
        setIsLoggingIn(true);

        try {
          const response = await fetch(GAS_WEB_APP_URL, {
            method: "POST",
            body: JSON.stringify({
              action: 'login',
              username: loginUsername,
              password: loginPassword
            })
          });
          const result = await response.json();

          if (result.status === 'success') {
            setCurrentUser(result.user);
            localStorage.setItem('smp_darul_madinah_user', JSON.stringify(result.user));
            if (result.user.role === 'admin') {
              setActiveTab('admin');
            } else {
              setActiveTab('upload');
            }
          } else {
            setAuthError(result.message || 'Username atau password salah.');
          }
        } catch (error) {
          setAuthError('Gagal terhubung ke server.');
        }
        setIsLoggingIn(false);
      };

      const handleLogout = () => {
        setCurrentUser(null);
        localStorage.removeItem('smp_darul_madinah_user');
        setLoginUsername('');
        setLoginPassword('');
      };

      // --- ADMIN HANDLERS ---
      const fetchUsers = async () => {
        if (!currentUser || currentUser.role !== 'admin') return;
        try {
          const response = await fetch(`${GAS_WEB_APP_URL}?action=getUsers`);
          const result = await response.json();
          if (result.status === 'success') {
            setUsersList(result.users);
          }
        } catch (error) {
          console.error("Gagal memuat user:", error);
        }
      };

      const handleSaveUser = async (e) => {
        e.preventDefault();
        if (!newUsername || !newPassword) return;
        setIsManagingUser(true);
        try {
          const response = await fetch(GAS_WEB_APP_URL, {
            method: "POST",
            body: JSON.stringify({
              action: 'saveUser',
              username: newUsername,
              password: newPassword,
              role: newRole
            })
          });
          const result = await response.json();
          if (result.status === 'success') {
            setNewUsername('');
            setNewPassword('');
            fetchUsers();
            alert("Berhasil menyimpan akun GTK!");
          }
        } catch (error) {
          alert("Gagal menyimpan akun.");
        }
        setIsManagingUser(false);
      };

      const handleStartEdit = (user) => {
        setEditingUser(user.username);
        setEditPasswordValue(user.password || '');
      };

      const handleCancelEdit = () => {
        setEditingUser(null);
        setEditPasswordValue('');
      };

      const handleSaveEdit = async (user) => {
        if (!editPasswordValue) {
          alert("Password tidak boleh kosong!");
          return;
        }
        setIsManagingUser(true);
        try {
          const response = await fetch(GAS_WEB_APP_URL, {
            method: "POST",
            body: JSON.stringify({
              action: 'saveUser',
              username: user.username,
              password: editPasswordValue,
              role: user.role
            })
          });
          const result = await response.json();
          if (result.status === 'success') {
            setEditingUser(null);
            setEditPasswordValue('');
            fetchUsers();
          }
        } catch (error) {
          alert("Gagal mengupdate password.");
        }
        setIsManagingUser(false);
      };

      const handleDeleteUser = async (usernameToDelete) => {
        if (!confirm(`Yakin ingin menghapus akun ${usernameToDelete}?`)) return;
        setIsManagingUser(true);
        try {
          const response = await fetch(GAS_WEB_APP_URL, {
            method: "POST",
            body: JSON.stringify({
              action: 'deleteUser',
              username: usernameToDelete
            })
          });
          const result = await response.json();
          if (result.status === 'success') {
            fetchUsers();
          }
        } catch (error) {
          alert("Gagal menghapus akun.");
        }
        setIsManagingUser(false);
      };

      useEffect(() => {
        if (currentUser && activeTab === 'admin') {
          fetchUsers();
        }
      }, [activeTab, currentUser]);


      // --- DATA & UPLOAD HANDLERS ---
      const fetchData = async () => {
        if (GAS_WEB_APP_URL === "ISI_DENGAN_URL_WEB_APP_ANDA_DISINI" || !currentUser) return;
        setIsLoadingData(true);
        try {
          const response = await fetch(`${GAS_WEB_APP_URL}?action=getData`);
          const result = await response.json();
          if (result.status === 'success') {
            const sortedActivities = result.activities.sort((a, b) => new Date(b.date) - new Date(a.date));
            setActivities(sortedActivities);
            setFilesMetadata(result.files);
          }
        } catch (error) {
          console.error("Gagal memuat data dari G-Drive", error);
        }
        setIsLoadingData(false);
      };

      useEffect(() => {
        if (currentUser && (activeTab === 'upload' || activeTab === 'folders')) {
          fetchData();
        }
      }, [currentUser]);

      const handleFileSelect = (e) => {
        if (!activityTitle.trim()) {
          alert("Mohon isi Judul Kegiatan terlebih dahulu.");
          e.target.value = '';
          return;
        }

        const files = Array.from(e.target.files);
        if (files.length === 0) return;

        const safeTitle = activityTitle.replace(/[^a-zA-Z0-9]/g, '_');
        const mappedFiles = files.map((file, index) => {
          const extension = file.name.split('.').pop();
          const newName = `${safeTitle}_${index + 1}.${extension}`;
          return {
            file, originalName: file.name, newName: newName,
            size: file.size, type: file.type, progress: 0,
            status: 'pending', id: Math.random().toString(36).substr(2, 9)
          };
        });

        setSelectedFiles(prev => [...prev, ...mappedFiles]);
        e.target.value = ''; 
      };

      const removeSelectedFile = (id) => setSelectedFiles(prev => prev.filter(f => f.id !== id));

      const fileToBase64 = (file) => new Promise((resolve, reject) => {
        const reader = new FileReader();
        reader.onload = () => resolve(reader.result.split(',')[1]);
        reader.onerror = error => reject(error);
        reader.readAsDataURL(file);
      });

      const startUpload = async () => {
        if (!activityTitle || !activityDate || selectedFiles.length === 0) return;
        setIsUploading(true);
        setActiveTab('monitor');

        const filesToUpload = [...selectedFiles];
        setUploadQueue(filesToUpload);
        setSelectedFiles([]); 

        for (let i = 0; i < filesToUpload.length; i++) {
          const fileObj = filesToUpload[i];
          setUploadQueue(prev => prev.map(f => f.id === fileObj.id ? { ...f, status: 'uploading', progress: 50 } : f));

          try {
            const base64Data = await fileToBase64(fileObj.file);
            
            const payload = {
              action: 'upload',
              activityTitle: activityTitle,
              activityDate: activityDate,
              fileName: fileObj.newName,
              mimeType: fileObj.type,
              fileData: base64Data
            };

            const response = await fetch(GAS_WEB_APP_URL, {
              method: "POST",
              body: JSON.stringify(payload)
            });

            const result = await response.json();
            
            if (result.status === 'success') {
              setUploadQueue(prev => prev.map(f => f.id === fileObj.id ? { ...f, status: 'completed', progress: 100 } : f));
            } else {
              throw new Error(result.message);
            }
          } catch (error) {
            setUploadQueue(prev => prev.map(f => f.id === fileObj.id ? { ...f, status: 'error', progress: 0 } : f));
          }
        }

        setIsUploading(false);
        setActivityTitle(''); 
        setActivityDate('');
        fetchData();
      };

      const formatBytes = (bytes) => {
        if (bytes === 0) return '0 Bytes';
        const k = 1024; const sizes = ['Bytes', 'KB', 'MB', 'GB'];
        const i = Math.floor(Math.log(bytes) / Math.log(k));
        return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
      };


      // --- RENDER LOGIN SCREEN ---
      if (!currentUser) {
        return (
          <div className="min-h-screen bg-slate-100 flex items-center justify-center p-4">
            <div className="bg-white p-8 rounded-2xl shadow-xl w-full max-w-md border border-slate-200">
              <div className="text-center mb-8">
                {!logoFailed ? (
                  <img src={LOGO_URL} alt="Logo" className="w-20 h-20 mx-auto object-contain shadow-sm mb-4" onError={() => setLogoFailed(true)} />
                ) : (
                  <div className="w-20 h-20 mx-auto bg-blue-600 rounded-full flex items-center justify-center shadow-sm mb-4">
                    <Shield className="text-white" size={36} />
                  </div>
                )}
                <h1 className="text-2xl font-bold text-slate-800">Login Portal GTK</h1>
                <p className="text-slate-500 text-sm mt-1">Sistem Dokumentasi SMP Darul Madinah</p>
              </div>

              {authError && (
                <div className="bg-red-50 text-red-600 p-3 rounded-lg text-sm mb-5 flex items-center">
                  <AlertCircle size={16} className="mr-2 flex-shrink-0" /> {authError}
                </div>
              )}

              <form onSubmit={handleLogin} className="space-y-5">
                <div>
                  <label className="block text-sm font-medium text-slate-700 mb-1">Username</label>
                  <div className="relative">
                    <User className="absolute left-3 top-1/2 transform -translate-y-1/2 text-slate-400" size={18} />
                    <input 
                      type="text" required
                      className="w-full pl-10 pr-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none" 
                      placeholder="Masukkan username..."
                      value={loginUsername} onChange={(e) => setLoginUsername(e.target.value)}
                    />
                  </div>
                </div>
                <div>
                  <label className="block text-sm font-medium text-slate-700 mb-1">Password</label>
                  <div className="relative">
                    <Lock className="absolute left-3 top-1/2 transform -translate-y-1/2 text-slate-400" size={18} />
                    <input 
                      type={showPassword ? "text" : "password"} required
                      className="w-full pl-10 pr-10 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none" 
                      placeholder="Masukkan password..."
                      value={loginPassword} onChange={(e) => setLoginPassword(e.target.value)}
                    />
                    <button 
                      type="button"
                      onClick={() => setShowPassword(!showPassword)}
                      className="absolute right-3 top-1/2 transform -translate-y-1/2 text-slate-400 hover:text-slate-600"
                    >
                      {showPassword ? <EyeOff size={18} /> : <Eye size={18} />}
                    </button>
                  </div>
                </div>
                <button 
                  type="submit" disabled={isLoggingIn}
                  className={`w-full py-2.5 rounded-lg text-white font-semibold shadow-sm transition ${isLoggingIn ? 'bg-blue-400' : 'bg-blue-600 hover:bg-blue-700'}`}
                >
                  {isLoggingIn ? 'Memeriksa...' : 'Masuk'}
                </button>
              </form>
            </div>
          </div>
        );
      }

      // --- RENDER MAIN APP ---
      return (
        <div className="min-h-screen font-sans bg-slate-100">
          <header className="bg-white border-b border-slate-200 shadow-sm sticky top-0 z-10">
            <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
              <div className="flex items-center">
                {!logoFailed ? (
                  <img src={LOGO_URL} alt="Logo SMP Darul Madinah" className="w-11 h-11 object-contain mr-3 shadow-sm" onError={() => setLogoFailed(true)} />
                ) : (
                  <div className="bg-blue-600 p-2 rounded-lg mr-3 shadow-sm"><HardDrive className="text-white" size={20} /></div>
                )}
                <div>
                  <h1 className="text-xl font-bold text-slate-800 leading-tight">SMP Darul Madinah</h1>
                  <p className="text-xs text-slate-500 font-medium tracking-wide flex items-center">
                    <span className={`px-1.5 py-0.5 rounded text-[10px] font-bold text-white mr-2 ${currentUser.role === 'admin' ? 'bg-amber-500' : 'bg-blue-500'}`}>
                      {currentUser.role === 'admin' ? 'ADMIN' : 'GTK'}
                    </span>
                    Selamat datang, {currentUser.username}
                  </p>
                </div>
              </div>
              <button onClick={handleLogout} className="flex items-center text-sm font-medium text-slate-600 hover:text-red-600 transition bg-slate-50 hover:bg-red-50 px-3 py-1.5 rounded-lg border border-slate-200">
                <LogOut size={16} className="mr-1.5" /> Keluar
              </button>
            </div>
          </header>

          <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 flex flex-col md:flex-row gap-8">
            <nav className="w-full md:w-64 flex-shrink-0 space-y-2">
              <button onClick={() => setActiveTab('upload')} className={`w-full flex items-center px-4 py-3 rounded-xl transition ${activeTab === 'upload' ? 'bg-blue-600 text-white shadow-md' : 'bg-white text-slate-600 border border-slate-200 hover:bg-slate-50'}`}><UploadCloud size={20} className="mr-3" /><span className="font-semibold">Upload Dokumen</span></button>
              <button onClick={() => setActiveTab('monitor')} className={`w-full flex items-center px-4 py-3 rounded-xl transition ${activeTab === 'monitor' ? 'bg-blue-600 text-white shadow-md' : 'bg-white text-slate-600 border border-slate-200 hover:bg-slate-50'}`}><Activity size={20} className="mr-3" /><span className="font-semibold">Pantau Upload</span></button>
              <button onClick={() => {setActiveTab('folders'); fetchData();}} className={`w-full flex items-center px-4 py-3 rounded-xl transition ${activeTab === 'folders' ? 'bg-blue-600 text-white shadow-md' : 'bg-white text-slate-600 border border-slate-200 hover:bg-slate-50'}`}><FolderOpen size={20} className="mr-3" /><span className="font-semibold">Galeri Drive</span></button>
              
              {/* TAB ADMIN KHUSUS ROLE ADMIN */}
              {currentUser.role === 'admin' && (
                <div className="pt-4 mt-4 border-t border-slate-200">
                  <button onClick={() => setActiveTab('admin')} className={`w-full flex items-center px-4 py-3 rounded-xl transition ${activeTab === 'admin' ? 'bg-amber-500 text-white shadow-md' : 'bg-white text-slate-600 border border-slate-200 hover:bg-amber-50 hover:text-amber-700 hover:border-amber-200'}`}>
                    <Shield size={20} className="mr-3" />
                    <span className="font-semibold">Panel Admin</span>
                  </button>
                </div>
              )}
            </nav>

            <main className="flex-1 min-w-0 pb-12">
              
              {/* TAMPILAN ADMIN */}
              {activeTab === 'admin' && currentUser.role === 'admin' && (
                <div className="space-y-6">
                  <div className="bg-white p-6 rounded-xl shadow-sm border border-slate-100">
                    <h2 className="text-xl font-semibold mb-4 flex items-center text-slate-800"><UserPlus className="mr-2 text-amber-500" size={24} /> Tambah Akun GTK Baru</h2>
                    <form onSubmit={handleSaveUser} className="grid grid-cols-1 md:grid-cols-3 gap-4 items-end bg-amber-50/50 p-4 rounded-lg border border-amber-100">
                      <div>
                        <label className="block text-sm font-medium mb-1 text-slate-700">Username</label>
                        <input type="text" required className="w-full border rounded-lg px-3 py-2 outline-none focus:ring-2 focus:ring-amber-500" value={newUsername} onChange={e => setNewUsername(e.target.value)} placeholder="Contoh: guru1" />
                      </div>
                      <div>
                        <label className="block text-sm font-medium mb-1 text-slate-700">Password</label>
                        <input type="password" required className="w-full border rounded-lg px-3 py-2 outline-none focus:ring-2 focus:ring-amber-500" value={newPassword} onChange={e => setNewPassword(e.target.value)} placeholder="Masukkan password" />
                      </div>
                      <div>
                        <button type="submit" disabled={isManagingUser} className="w-full bg-amber-500 hover:bg-amber-600 text-white font-medium py-2 rounded-lg transition disabled:bg-amber-300">
                          {isManagingUser ? 'Menyimpan...' : 'Simpan Akun'}
                        </button>
                      </div>
                    </form>
                  </div>

                  <div className="bg-white p-6 rounded-xl shadow-sm border border-slate-100">
                    <div className="flex justify-between items-center mb-4">
                      <h2 className="text-xl font-semibold flex items-center text-slate-800"><Users className="mr-2 text-blue-600" size={24} /> Daftar Akun Pengguna</h2>
                      <button onClick={fetchUsers} className="text-sm border px-3 py-1.5 rounded-lg hover:bg-slate-50">Refresh</button>
                    </div>
                    <div className="overflow-x-auto border border-slate-200 rounded-lg">
                      <table className="w-full text-left text-sm">
                        <thead className="bg-slate-50 border-b border-slate-200">
                          <tr>
                            <th className="p-3">Username</th>
                            <th className="p-3">Role / Hak Akses</th>
                            <th className="p-3">Password</th>
                            <th className="p-3 text-center">Aksi</th>
                          </tr>
                        </thead>
                        <tbody>
                          {usersList.length === 0 ? (
                            <tr><td colSpan="4" className="p-4 text-center text-slate-500 italic">Memuat data pengguna...</td></tr>
                          ) : usersList.map((user, idx) => (
                            <tr key={idx} className="border-b border-slate-100 hover:bg-slate-50">
                              <td className="p-3 font-medium text-slate-800">{user.username}</td>
                              <td className="p-3">
                                <span className={`px-2 py-1 rounded text-xs font-semibold ${user.role === 'admin' ? 'bg-amber-100 text-amber-800' : 'bg-blue-100 text-blue-800'}`}>
                                  {user.role.toUpperCase()}
                                </span>
                              </td>
                              <td className="p-3">
                                {editingUser === user.username ? (
                                  <input 
                                    type="text" 
                                    value={editPasswordValue} 
                                    onChange={(e) => setEditPasswordValue(e.target.value)}
                                    className="border border-slate-300 rounded px-2 py-1 w-full text-sm outline-none focus:ring-1 focus:ring-amber-500"
                                    placeholder="Password baru..."
                                  />
                                ) : (
                                  <span className="font-mono text-slate-600 bg-slate-100 px-2 py-1 rounded">{user.password || '******'}</span>
                                )}
                              </td>
                              <td className="p-3 text-center">
                                {editingUser === user.username ? (
                                  <div className="flex justify-center gap-2">
                                    <button onClick={() => handleSaveEdit(user)} className="text-emerald-600 hover:bg-emerald-50 p-1.5 rounded transition" title="Simpan">
                                      <Save size={16}/>
                                    </button>
                                    <button onClick={handleCancelEdit} className="text-slate-500 hover:bg-slate-100 p-1.5 rounded transition" title="Batal">
                                      <X size={16}/>
                                    </button>
                                  </div>
                                ) : (
                                  <div className="flex justify-center gap-2">
                                    <button onClick={() => handleStartEdit(user)} disabled={isManagingUser} className="text-blue-500 hover:bg-blue-50 p-1.5 rounded transition" title="Edit Password">
                                      <Edit2 size={16}/>
                                    </button>
                                    {user.role !== 'admin' && (
                                      <button onClick={() => handleDeleteUser(user.username)} disabled={isManagingUser} className="text-red-500 hover:bg-red-50 p-1.5 rounded transition" title="Hapus Akun">
                                        <Trash2 size={16}/>
                                      </button>
                                    )}
                                  </div>
                                )}
                              </td>
                            </tr>
                          ))}
                        </tbody>
                      </table>
                    </div>
                  </div>
                </div>
              )}

              {/* TAMPILAN UPLOAD */}
              {activeTab === 'upload' && (
                <div className="bg-white p-6 rounded-xl shadow-sm border border-slate-100">
                  <h2 className="text-xl font-semibold mb-4 flex items-center"><UploadCloud className="mr-2 text-blue-600" size={24} /> Upload ke G-Drive</h2>
                  <div className="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
                    <div><label className="block text-sm font-medium mb-1 text-slate-700">Judul Kegiatan</label><input type="text" className="w-full border rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none" value={activityTitle} onChange={(e) => setActivityTitle(e.target.value)} placeholder="Contoh: Porseni 2024" /></div>
                    <div><label className="block text-sm font-medium mb-1 text-slate-700">Tanggal Kegiatan</label><input type="date" className="w-full border rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none" value={activityDate} onChange={(e) => setActivityDate(e.target.value)} /></div>
                  </div>
                  <div className={`border-2 border-dashed rounded-xl p-8 text-center transition ${activityTitle ? 'bg-blue-50 border-blue-300' : 'bg-slate-50 border-slate-300'}`}>
                    {activityTitle ? (
                      <>
                        <p className="mb-4 text-slate-700 font-medium">Pilih file untuk Kegiatan "{activityTitle}"</p>
                        <button onClick={() => fileInputRef.current.click()} className="bg-blue-600 hover:bg-blue-700 transition text-white px-6 py-2 rounded-lg font-medium shadow-sm">Jelajahi File</button>
                        <input type="file" multiple className="hidden" ref={fileInputRef} onChange={handleFileSelect} />
                      </>
                    ) : (<p className="text-slate-500">Isi Judul Kegiatan terlebih dahulu.</p>)}
                  </div>
                  
                  {selectedFiles.length > 0 && (
                    <div className="mt-6 border-t border-slate-200 pt-4">
                      <div className="flex justify-between items-center mb-4">
                        <h3 className="font-semibold text-slate-800">Preview Penamaan Massal ({selectedFiles.length} File)</h3>
                        <button onClick={startUpload} disabled={isUploading || !activityDate} className={`px-5 py-2 rounded-lg text-white font-medium transition flex items-center ${!activityDate ? 'bg-slate-300 cursor-not-allowed' : 'bg-emerald-600 hover:bg-emerald-700 shadow-sm'}`}>
                          {isUploading ? 'Memproses...' : 'Mulai Upload'}
                        </button>
                      </div>
                      {!activityDate && <p className="text-red-500 text-sm mb-3">Peringatan: Isi Tanggal Kegiatan sebelum upload.</p>}
                      <div className="overflow-x-auto">
                        <table className="w-full text-left text-sm"><thead className="bg-slate-50"><tr><th className="p-3 border-b border-slate-200 text-slate-700 font-semibold">Nama Asli</th><th className="p-3 border-b border-slate-200 text-slate-700 font-semibold">Nama Baru (Otomatis)</th><th className="p-3 border-b border-slate-200 text-slate-700 font-semibold text-center">Aksi</th></tr></thead>
                        <tbody>{selectedFiles.map(f => (
                          <tr key={f.id} className="border-b border-slate-100 hover:bg-slate-50 transition"><td className="p-3 text-slate-600 truncate max-w-[150px]">{f.originalName}</td><td className="p-3 text-blue-700 font-medium truncate max-w-[200px]">{f.newName}</td><td className="p-3 text-center"><button onClick={() => removeSelectedFile(f.id)} className="text-red-500 hover:bg-red-50 p-1.5 rounded transition"><Trash2 size={16}/></button></td></tr>
                        ))}</tbody></table>
                      </div>
                    </div>
                  )}
                </div>
              )}

              {/* TAMPILAN MONITOR */}
              {activeTab === 'monitor' && (
                <div className="bg-white p-6 rounded-xl shadow-sm border border-slate-100">
                  <h2 className="text-xl font-semibold mb-6 flex items-center text-slate-800"><Activity className="mr-2 text-blue-600" size={24} /> Pantauan Upload</h2>
                  {uploadQueue.length === 0 ? <p className="text-slate-500 text-center py-10 flex flex-col items-center"><Clock size={48} className="text-slate-300 mb-3"/>Belum ada antrean.</p> : (
                    <div className="space-y-4">
                      {uploadQueue.map(file => (
                        <div key={file.id} className={`p-4 rounded-lg border transition-all ${file.status === 'error' ? 'bg-red-50 border-red-200' : file.status === 'completed' ? 'bg-emerald-50 border-emerald-200' : 'bg-white border-slate-200 shadow-sm'}`}>
                          <div className="flex justify-between items-center mb-2">
                            <span className="font-medium text-slate-700">{file.newName}</span>
                            <span className={`text-sm font-bold ${file.status === 'completed' ? 'text-emerald-600' : file.status === 'error' ? 'text-red-600' : 'text-blue-600'}`}>
                              {file.status === 'completed' ? 'Selesai' : file.status === 'error' ? 'Gagal' : 'Mengunggah...'}
                            </span>
                          </div>
                          {file.status !== 'error' && file.status !== 'completed' && (
                             <div className="w-full bg-slate-100 rounded-full h-2.5 overflow-hidden"><div className="bg-blue-600 h-2.5 rounded-full w-full animate-pulse"></div></div>
                          )}
                        </div>
                      ))}
                    </div>
                  )}
                </div>
              )}

              {/* TAMPILAN FOLDER */}
              {activeTab === 'folders' && (
                <div className="space-y-6">
                  <div className="flex flex-col md:flex-row justify-between items-center mb-6 gap-4">
                    <h2 className="text-2xl font-bold flex items-center text-slate-800"><FolderOpen className="mr-2 text-blue-600" size={28} /> Isi Google Drive</h2>
                    <div className="flex items-center gap-3 w-full md:w-auto">
                      <button onClick={fetchData} className="text-sm bg-white border border-slate-300 hover:bg-slate-50 transition px-4 py-2 rounded-lg text-slate-700 font-medium">{isLoadingData ? 'Menyegarkan...' : 'Refresh Data'}</button>
                      <div className="relative flex-1 md:w-64">
                        <Search className="absolute left-3 top-1/2 transform -translate-y-1/2 text-slate-400" size={16} />
                        <input type="text" placeholder="Cari kegiatan..." className="border rounded-lg pl-9 pr-4 py-2 w-full focus:ring-2 focus:ring-blue-500 outline-none" value={searchQuery} onChange={(e) => setSearchQuery(e.target.value)} />
                      </div>
                    </div>
                  </div>
                  
                  {isLoadingData && activities.length === 0 ? (
                    <div className="text-center py-10 text-slate-500 font-medium animate-pulse">Membaca struktur folder dari Google Drive...</div>
                  ) : activities.filter(a => a.title.toLowerCase().includes(searchQuery.toLowerCase())).length === 0 ? (
                    <div className="bg-white p-10 rounded-xl border border-slate-100 text-center text-slate-500 shadow-sm"><FolderOpen className="mx-auto text-slate-300 mb-3" size={48}/>Belum ada folder kegiatan di G-Drive.</div>
                  ) : (
                    activities.filter(a => a.title.toLowerCase().includes(searchQuery.toLowerCase())).map(activity => {
                      const currentFiles = filesMetadata.filter(f => f.activityId === activity.id);
                      return (
                      <div key={activity.id} className="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden mb-6 transition hover:shadow-md">
                        <div className="bg-slate-50 px-6 py-4 border-b border-slate-200 flex justify-between items-center">
                          <div>
                            <h3 className="text-lg font-bold text-slate-800">{activity.title}</h3>
                            <p className="text-sm text-slate-500 flex items-center mt-0.5"><Clock size={14} className="mr-1"/> {activity.date}</p>
                          </div>
                          <a href={activity.url} target="_blank" rel="noreferrer" className="text-blue-700 hover:text-blue-900 bg-blue-100 px-3 py-1.5 rounded-lg text-sm font-semibold flex items-center transition"><ExternalLink size={16} className="mr-1.5"/> Buka Folder</a>
                        </div>
                        <div className="p-6">
                          {currentFiles.length === 0 ? <p className="text-slate-400 text-sm italic">Belum ada file di folder ini.</p> : (
                            <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                              {currentFiles.map(file => (
                                <div key={file.id} className="border border-slate-200 hover:border-blue-400 p-3 rounded-lg flex items-start bg-white transition group relative overflow-hidden">
                                  <FilePreview file={file} />
                                  <div className="flex-1 min-w-0">
                                    <p className="text-sm font-semibold truncate text-slate-800" title={file.newName}>{file.newName}</p>
                                    <p className="text-xs text-slate-500 mt-0.5">{formatBytes(file.size)}</p>
                                    <div className="flex gap-2 mt-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                      <a href={file.url} target="_blank" rel="noreferrer" className="text-xs font-medium bg-slate-100 hover:bg-blue-100 text-blue-700 px-2 py-1 rounded transition">Lihat</a>
                                      <a href={file.downloadUrl} className="text-xs font-medium bg-slate-100 hover:bg-emerald-100 text-emerald-700 px-2 py-1 rounded transition">Unduh</a>
                                    </div>
                                  </div>
                                </div>
                              ))}
                            </div>
                          )}
                        </div>
                      </div>
                    )})
                  )}
                </div>
              )}
            </main>
          </div>
        </div>
      );
    }

    const root = createRoot(document.getElementById('root'));
    root.render(<App />);
  </script>
</body>
</html>
